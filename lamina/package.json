{
  "name": "lamina-flow",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "generate": "turbo run generate",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "npm@10.8.2",
  "devDependencies": {
    "prettier": "^3.0.0",
    "turbo": "latest"
  }
}